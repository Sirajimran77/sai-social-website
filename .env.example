# ── SAI Social — environment configuration ──────────────────────────────────
# Copy this file to ".env" and fill in the values, then restart the server.
# The .env file holds secrets — never commit it to git (it is gitignored).

# Port the server listens on (most hosts set this automatically).
PORT=3000

# Where booking enquiries are delivered.
TO_EMAIL=saimanagement77@gmail.com

# ── SMTP (outgoing mail) ─────────────────────────────────────────────────────
# Easiest option: a Gmail account + an "App Password".
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:        https://myaccount.google.com/apppasswords
#   3. Paste the 16-character password (no spaces) into SMTP_PASS below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=saimanagement77@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional: the "From" address shown on the email.
# Defaults to SMTP_USER if left blank.
FROM_EMAIL="SAI Social Website <saimanagement77@gmail.com>"
